--- a/vp9/encoder/vp9_ratectrl.c
+++ b/vp9/encoder/vp9_ratectrl.c
@@ -1741,5 +1741,9 @@
   // Target rate per SB64 (including partial SB64s.
   const int64_t sb64_target_rate =
       ((int64_t)rc->this_frame_target * 64 * 64) / (cm->width * cm->height);
-  rc->sb64_target_rate = (int)VPXMIN(sb64_target_rate, INT_MAX);
+  // strict fix (FB-Bench differential): clamp so the CAQ invariant
+  // sb64_target_rate < INT_MAX / 256 (vp9_aq_complexity.c) holds and
+  // the subsequent *256 scale cannot overflow / trip the assert.
+  rc->sb64_target_rate =
+      (int)VPXMIN(sb64_target_rate, (int64_t)(INT_MAX / 256) - 1);
 }
