diff --git a/pngrutil.c b/pngrutil.c
index 6d937c8..5dfb2fd 100644
--- a/pngrutil.c
+++ b/pngrutil.c
@@ -381,6 +381,20 @@ png_read_buffer(png_struct *png_ptr, png_alloc_size_t new_size)
 
    if (buffer != NULL && new_size > png_ptr->read_buffer_size)
    {
+      /* strict fix (FB-Bench differential): png_inflate() stores read_buffer (plus a
+       * prefix) directly into png_ptr->zstream.next_in.  Freeing the old buffer
+       * here without touching the zstream leaves next_in dangling; a later call
+       * into png_zlib_inflate() then dereferences it (use-after-free).  Drop any
+       * stream input that points into the block we are about to free.
+       */
+      if (png_ptr->zstream.next_in != NULL &&
+          png_ptr->zstream.next_in >= buffer &&
+          png_ptr->zstream.next_in < buffer + png_ptr->read_buffer_size)
+      {
+         png_ptr->zstream.next_in = NULL;
+         png_ptr->zstream.avail_in = 0;
+      }
+
       png_ptr->read_buffer = NULL;
       png_ptr->read_buffer_size = 0;
       png_free(png_ptr, buffer);
