# Off-target ablation Arm-B tree: commit ONLY the binaries/ (LFS); the source
# symlinks are absolute and machine-local — regenerate with
#   tools/offtarget/stage_armB.py --relink
bugs-armB/*/*/*
!bugs-armB/*/*/binaries

# Sealed-challenge oracle bundles: machine-local symlinks to answer dirs, and
# the build report — regenerated by tools/sealed/build_all.py. Never commit.
tools/sealed/oracle-root/
tools/sealed/build_report.json
